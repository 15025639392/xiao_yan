# Backend local environment template for xiao_yan core.
# Copy this file to services/core/.env.local and fill only the items you need.
# Existing shell environment variables have higher priority and will not be overwritten.

# -----------------------------------------------------------------------------
# LLM provider: recommended default path
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4
# OPENAI_WIRE_API=responses

# Optional: explicitly choose which configured provider the chat runtime uses.
# Allowed values depend on which providers are actually configured.
# CHAT_PROVIDER=openai

# Optional: override the chat model independently from the provider default.
# CHAT_MODEL=gpt-5.4

# -----------------------------------------------------------------------------
# Alternative built-in providers
# -----------------------------------------------------------------------------
# DEEPSEEK_API_KEY=<YOUR_DEEPSEEK_API_KEY>
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_WIRE_API=chat

# MINIMAX_API_KEY=<YOUR_MINIMAX_API_KEY>
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_WIRE_API=chat

# -----------------------------------------------------------------------------
# Custom provider registration
# -----------------------------------------------------------------------------
# Comma-separated provider ids. Example:
# LLM_PROVIDER_IDS=moonshot,openrouter
#
# For each id above, configure the matching variables below with the uppercased
# and "_" normalized token. Example for "moonshot":
# LLM_PROVIDER_MOONSHOT_NAME=Moonshot
# LLM_PROVIDER_MOONSHOT_API_KEY=<YOUR_API_KEY>
# LLM_PROVIDER_MOONSHOT_BASE_URL=https://api.example.com/v1
# LLM_PROVIDER_MOONSHOT_MODEL=gpt-5.4
# LLM_PROVIDER_MOONSHOT_WIRE_API=responses

# -----------------------------------------------------------------------------
# Chat runtime knobs
# -----------------------------------------------------------------------------
# CHAT_CONTEXT_LIMIT=6
# CHAT_READ_TIMEOUT_SECONDS=180
# CHAT_KNOWLEDGE_EXTRACTION_ENABLED=false

# -----------------------------------------------------------------------------
# Data paths
# Defaults all live under services/core/.data/.
# -----------------------------------------------------------------------------
# WORLD_STORAGE_PATH=/absolute/path/to/world.json
# STATE_STORAGE_PATH=/absolute/path/to/state.json
# PERSONA_STORAGE_PATH=/absolute/path/to/persona.json
# CAPABILITY_QUEUE_STORAGE_PATH=/absolute/path/to/capability_queue.json

# -----------------------------------------------------------------------------
# MemPalace / long-term memory
# MEMPALACE_PALACE_PATH is restricted to services/core and falls back to the
# default path if you point it outside the service directory.
# -----------------------------------------------------------------------------
# MEMPALACE_PALACE_PATH=.mempalace/palace
# MEMPALACE_RESULTS_LIMIT=3
# MEMPALACE_WING=wing_xiaoyan
# MEMPALACE_ROOM=chat_exchange

# -----------------------------------------------------------------------------
# Optional feature flags
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Advanced local developer options
# -----------------------------------------------------------------------------
# CHAT_SKILL_ROOTS=/absolute/path/to/skills:/another/path/to/skills
# MAC_CONSOLE_BOOTSTRAP_ENABLED=1
# MAC_CONSOLE_BOOTSTRAP_TIMEOUT_SECONDS=180
# MAC_CONSOLE_BOOTSTRAP_SCRIPT=/absolute/path/to/bootstrap_mac_console.sh
